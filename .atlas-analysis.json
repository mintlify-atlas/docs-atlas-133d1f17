  "keyFeatures": [
    "AI-powered content generation using Google Gemini",
    "Multi-language voice narration with Sarvam AI TTS",
    "Dynamic Manim animations for mathematical and scientific concepts",
    "Smart visual media integration with Unsplash images",
    "Professional video composition with FFmpeg",
    "Real-time progress tracking with Server-Sent Events",
    "Interactive slide editor with drag-and-drop timeline",
    "PowerPoint export functionality",
    "Customizable tone and language options"
  ],
  "publicApiSurface": [
    "POST /api/generate - Generate video presentation from topic",
    "GET /api/progress/{generation_id} - Stream real-time generation progress",
    "GET /api/status/{generation_id} - Get generation status",
    "GET /api/video/{filename} - Stream generated video with range support",
    "GET /api/content/{generation_id} - Get generated content data",
    "GET /api/script/{generation_id} - Get generated script data",
    "ContentGenerator.generate_content() - Generate presentation structure",
    "ScriptGenerator.generate_scripts() - Generate narration scripts",
    "VoiceGenerator.generate_voice_for_slide() - Generate audio per slide",
    "ManimGenerator.generate_animation_code() - Generate Manim animation code",
    "ImageFetcher.fetch_image() - Fetch relevant images from Unsplash",
    "VideoComposer.compose_final_video() - Compose final video with audio"
  ]
